    <geom contype="1" conaffinity="1" condim="6"
          friction="1.0 0.1 0.1"
          solref="0.01 1.0"
          solimp="0.9 0.95 0.001"
          margin="0.0005"/>

    <default class="guide_site">
      <site size="0.0030" rgba="1 1 0 1"/>
    </default>

    <default class="anchor_site">
      <site size="0.0045" rgba="1 0.2 0.2 1"/>
    </default>

    <default class="visual_mesh">
      <geom type="mesh" contype="0" conaffinity="0"/>
    </default>

    <default class="hand_collision">
      <geom type="capsule"
            contype="2" conaffinity="5"
            condim="6"
            friction="0.4 0.05 0.05"
            solref="0.001 1"
            solimp="0.95 0.99 0.001"
            margin="0.0005"
            rgba="1 0 0 0"/>
    </default>
