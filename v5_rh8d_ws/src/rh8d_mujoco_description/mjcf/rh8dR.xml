              </body>
            </body>
          </body>

        </body>
      </body>
    </body>
  </worldbody>

  <!-- RH8D: Spatial tendons -->
  <tendon>
    <spatial name="idx_flex_spatial" rgba="1 0 1 1" width="0.002" damping="6" frictionloss="0.3">
      <site site="palm_flexor_origin_idx"/>
      <site site="idx_guide_p"/>
      <site site="idx_guide_m"/>
      <site site="idx_guide_d"/>
      <site site="idx_anchor"/>
    </spatial>

    <spatial name="mid_flex_spatial" rgba="1 0 1 1" width="0.002" damping="6" frictionloss="0.3">
      <site site="palm_flexor_origin_mid"/>
      <site site="mid_guide_p"/>
      <site site="mid_guide_m"/>
      <site site="mid_guide_d"/>
      <site site="mid_anchor"/>
    </spatial>

    <spatial name="ring_flex_spatial" rgba="1 0 1 1" width="0.002" damping="6" frictionloss="0.3">
      <site site="palm_flexor_origin_ring_small"/>
      <site site="ring_guide_p"/>
      <site site="ring_guide_m"/>
      <site site="ring_guide_d"/>
      <site site="ring_anchor"/>
    </spatial>

    <spatial name="sml_flex_spatial" rgba="1 0 1 1" width="0.002" damping="6" frictionloss="0.3">
      <site site="palm_flexor_origin_ring_small"/>
      <site site="sml_guide_p"/>
      <site site="sml_guide_m"/>
      <site site="sml_guide_d"/>
      <site site="sml_anchor"/>
    </spatial>

    <spatial name="th_flex_spatial" rgba="1 0 1 1" width="0.002" damping="6" frictionloss="0.3">
      <site site="palm_flexor_origin_thumb"/>
      <site site="th_guide_p"/>
      <site site="th_guide_m"/>
      <site site="th_guide_d"/>
      <site site="th_guide_distal"/>
      <site site="th_anchor"/>
    </spatial>
  </tendon>

  <!-- RH8D: ring and small finger are driven by the same actuator -->
  <equality>
    <tendon tendon1="sml_flex_spatial" tendon2="ring_flex_spatial"
            polycoef="0 1 0 0 0"
            solref="0.08 1.0"
            solimp="0.90 0.99 0.002"/>
  </equality>

  <!-- Actuators for RH8D -->
  <actuator>
    <!-- RH8D: wrist/palm actuators -->
    <position name="pos_forearm" joint="forearm:1--base:1"
              kp="5" kv="1" forcelimited="true" forcerange="-5 5"
              ctrllimited="true" ctrlrange="-1.5708 1.5708"/>

    <position name="pos_palm_axis" joint="palm_axis:1--forearm:1"
              kp="5" kv="1" forcelimited="true" forcerange="-5 5"
              ctrllimited="true" ctrlrange="-1.5708 1.5708"/>

    <position name="pos_palm_assembly" joint="palm_assembly:1--palm_axis:1"
              kp="5" kv="1" forcelimited="true" forcerange="-5 5"
              ctrllimited="true" ctrlrange="-0.785398 0.785398"/>

    <position name="pos_thumb_axis" joint="Thumb_axis--palm_assembly:1"
              kp="5" kv="1" forcelimited="true" forcerange="-5 5"
              ctrllimited="true" ctrlrange="0.0 1.5708"/>

    <!-- RH8D: Tendon driven finger actuators -->
    <position name="pos_index_tendon" tendon="idx_flex_spatial"
              kp="80" dampratio="0.5" forcelimited="true" forcerange="0 180"
              ctrllimited="true" ctrlrange="0.0 1.5708"/>

    <position name="pos_middle_tendon" tendon="mid_flex_spatial"
              kp="80" dampratio="0.5" forcelimited="true" forcerange="0 180"
              ctrllimited="true" ctrlrange="0.0 1.5708"/>

    <position name="pos_ring_small_tendon" tendon="ring_flex_spatial"
              kp="80" dampratio="0.5" forcelimited="true" forcerange="0 180"
              ctrllimited="true" ctrlrange="0.0 1.5708"/>

    <position name="pos_thumb_tendon" tendon="th_flex_spatial"
              kp="60" dampratio="0.5" forcelimited="true" forcerange="0 180"
              ctrllimited="true" ctrlrange="0.0 1.5708"/>
  </actuator>

  <!-- RH8D: Sensors including TOF and force sensors -->
  <sensor>
    <!-- Tendon positions -->
    <tendonpos name="len_index"  tendon="idx_flex_spatial"/>
    <tendonpos name="len_middle" tendon="mid_flex_spatial"/>
    <tendonpos name="len_ring"   tendon="ring_flex_spatial"/>
    <tendonpos name="len_small"  tendon="sml_flex_spatial"/>
    <tendonpos name="len_thumb"  tendon="th_flex_spatial"/>

    <!-- Tendon actuator forces -->
    <actuatorfrc name="frc_index"  actuator="pos_index_tendon"/>
    <actuatorfrc name="frc_middle" actuator="pos_middle_tendon"/>
    <actuatorfrc name="frc_ring"   actuator="pos_ring_small_tendon"/>
    <actuatorfrc name="frc_thumb"  actuator="pos_thumb_tendon"/>

    <!-- Palm distance sensor -->
    <rangefinder name="palm_range" site="palm_range_site"/>

    <!-- 3-axis fingertip force sensors -->
    <force name="thumb_tip_force"  site="thumb_tip_force_site"/>
    <force name="index_tip_force"  site="index_tip_force_site"/>
    <force name="middle_tip_force" site="middle_tip_force_site"/>
    <force name="ring_tip_force"   site="ring_tip_force_site"/>
    <force name="small_tip_force"  site="small_tip_force_site"/>
  </sensor>

  <!-- RH8D: Contact excludes -->
  <contact>
    <exclude body1="forearm:1" body2="palm_axis:1"/>
    <exclude body1="palm_axis:1" body2="palm_assembly:1"/>
    <exclude body1="Thumb_axis" body2="Thumb_Methacarpal"/>
    <exclude body1="Thumb_Methacarpal" body2="Thumb_Proximal"/>
    <exclude body1="Thumb_Proximal" body2="Thumb_Distal"/>
    <exclude body1="Index_Proximal" body2="Index_Middle"/>
    <exclude body1="Index_Middle" body2="Index_Distal"/>
    <exclude body1="Middle_Proximal" body2="Middle_Middle"/>
    <exclude body1="Middle_Middle" body2="Middle_Distal"/>
    <exclude body1="Ring_Proximal" body2="Ring_Middle"/>
    <exclude body1="Ring_Middle" body2="Ring_Distal"/>
    <exclude body1="Small_Proximal" body2="Small_Middle"/>
    <exclude body1="Small_Middle" body2="Small_Distal"/>

    <exclude body1="palm_assembly:1" body2="Index_Proximal"/>
    <exclude body1="palm_assembly:1" body2="Index_Middle"/>
    <exclude body1="palm_assembly:1" body2="Index_Distal"/>
    <exclude body1="palm_assembly:1" body2="Middle_Proximal"/>
    <exclude body1="palm_assembly:1" body2="Middle_Middle"/>
    <exclude body1="palm_assembly:1" body2="Middle_Distal"/>
    <exclude body1="palm_assembly:1" body2="Ring_Proximal"/>
    <exclude body1="palm_assembly:1" body2="Ring_Middle"/>
    <exclude body1="palm_assembly:1" body2="Ring_Distal"/>
    <exclude body1="palm_assembly:1" body2="Small_Proximal"/>
    <exclude body1="palm_assembly:1" body2="Small_Middle"/>
    <exclude body1="palm_assembly:1" body2="Small_Distal"/>
    <exclude body1="palm_assembly:1" body2="Thumb_axis"/>
    <exclude body1="palm_assembly:1" body2="Thumb_Methacarpal"/>
    <exclude body1="palm_assembly:1" body2="Thumb_Proximal"/>
    <exclude body1="palm_assembly:1" body2="Thumb_Distal"/>
  </contact>

</mujoco>