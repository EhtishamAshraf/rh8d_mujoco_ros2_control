<?xml version="1.0"?>
<mujoco model="RH8D Right Hand Scene">

  <include file="rh8dR.xml"/>

  <statistic center="0.15 0 0" extent="0.6" meansize="0.01"/>

  <visual>
    <headlight diffuse=".8 .8 .8" ambient=".2 .2 .2" specular="1 1 1"/>
    <global azimuth="120" elevation="-20"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.62 0.78 0.97" rgb2="0.10 0.25 0.55"
             width="800" height="800"/>

    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.20 0.45 0.80" rgb2="0.12 0.28 0.55" markrgb="0.9 0.9 0.9"
             width="512" height="512"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="8 8" reflectance="0.05"/>

    <texture name="tex_table" type="2d" builtin="checker"
             rgb1="0.55 0.55 0.55" rgb2="0.25 0.25 0.25"
             width="512" height="512"/>
    <material name="mat_table" texture="tex_table" texrepeat="4 4"
              reflectance="0.2" shininess="0.1" specular="0.1"/>

    <material name="mat_cyl" rgba="0.85 0.15 0.15 1"/>
    <material name="mat_ball" rgba="0.0 0.5 1.0 1"/>
  </asset>

  <worldbody>
    <camera name="side" pos="0.25 0.45 0.35"
            xyaxes="0.78 -0.62 0.00  -0.33 -0.42 0.85"/>

    <!-- Floor & Table & Objects -->
    <!-- contype=1, conaffinity=6 (collide with HAND=2 and OBJECT=4) -->
    <geom name="floor" pos="0 0 -0.25" size="0 0 0.01" type="plane"
          material="groundplane"
          contype="1" conaffinity="6"/>

    <body name="table" pos="0 0 0.045">
      <geom name="table_top" type="box" size="0.5 0.5 0.05"
            material="mat_table" pos="0 0 0.045"
            contype="1" conaffinity="6"/>
    </body>

    <body name="cylinder_object" pos="-0.002 0 0.2">
      <freejoint/>
      <geom name="cyl" type="cylinder" size="0.025 0.06"
            material="mat_cyl"
            density="900"
            friction="0.4 0.05 0.05"
            solref="0.001 1"
            solimp="0.95 0.999 0.001"
            contype="4" conaffinity="3" condim="6"/>
    </body>

    <body name="tennis_ball" pos="-0.0005 0.23 0.2">
      <freejoint/>
      <geom name="ball" type="sphere" size="0.033"
            material="mat_ball"  
            density="800"        
            friction="0.75 0.185 0.185"
            solref="0.003 1"
            solimp="0.90 0.97 0.001"
            contype="4" conaffinity="3" condim="6"/>
    </body>

  </worldbody>
</mujoco>

